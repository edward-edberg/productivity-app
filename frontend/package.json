{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "env -u __NEXT_PRIVATE_STANDALONE_CONFIG -u __NEXT_PRIVATE_ORIGIN next dev",
    "build": "env -u __NEXT_PRIVATE_STANDALONE_CONFIG -u __NEXT_PRIVATE_ORIGIN next build",
    "start": "next start",
    "lint": "eslint",
    "test": "env -u NODE_ENV vitest run",
    "test:unit": "env -u NODE_ENV vitest run",
    "test:unit:watch": "env -u NODE_ENV vitest",
    "test:e2e": "env -u NODE_ENV playwright test",
    "test:all": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "happy-dom": "^20.9.0",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
